generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_XViKLYTgz5l6@ep-wispy-dust-alczp7rk-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model User {
  id        String   @id @default(cuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String   @unique
  password  String
  role      String   @default("acheteur")
  ville     String?
  verifie   Boolean  @default(false)
  createdAt DateTime @default(now())
  annonces  Annonce[]
}

model Annonce {
  id          String   @id @default(cuid())
  marque      String
  modele      String
  annee       Int
  kilometrage Int
  carburant   String
  boite       String
  couleur     String
  prix        Int
  ville       String
  description String
  statut      String   @default("en_attente")
  dedouane    Boolean  @default(false)
  photos      String   @default("[]")
  createdAt   DateTime @default(now())
  vendeurId   String
  vendeur     User     @relation(fields: [vendeurId], references: [id])
}